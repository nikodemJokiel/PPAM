<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#90EE90"
    tools:context=".MainActivity">


    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:background="@color/SeaGreen"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:text="Wizyta u weterynarza" />

    <EditText
        android:id="@+id/imieNazwisko"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:hint="Imię i nazwisko właściela..." />

    <TextView
        android:id="@+id/gatunek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gatunek" />

    <ListView
        android:id="@+id/listaGatunkow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
            />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">


        <TextView
            android:id="@+id/wiek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ile ma lat? 0"
            android:textSize="20sp" />

        <SeekBar
            android:id="@+id/wiekSlider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="20"
            android:progress="0" />
    </LinearLayout>

    <EditText
        android:id="@+id/cel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:hint="Cel wizyty" />

    <EditText
        android:id="@+id/godzina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="time"
        android:text="16:00"/>

    <Button
        android:id="@+id/buttonOk"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:text="OK" />

    <TextView
        android:id="@+id/komunikat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />


</LinearLayout>